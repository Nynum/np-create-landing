# ═══════════════════════════════════════════════════════════
#  NP Create — environment variables
#  Copy this file to `.env.local` and fill in real values.
# ═══════════════════════════════════════════════════════════

# ─── Site ───
NEXT_PUBLIC_SITE_URL=https://nynum.com

# ─── Resend (contact form email) ───
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM=no-reply@nynum.com
CONTACT_EMAIL=hello@nynum.com

# ─── Tracking (set whichever you use, leave blank to disable) ───
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX                   # Google Analytics 4
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX                   # Google Tag Manager (umbrella)
NEXT_PUBLIC_META_PIXEL_ID=000000000000000        # Meta Pixel (Facebook + Instagram)
NEXT_PUBLIC_TIKTOK_PIXEL_ID=XXXXXXXXXXXXXXXXXXXX # TikTok Pixel
NEXT_PUBLIC_LINE_TAG_ID=00000000                 # LINE Tag (LAP)

# ─── Server-side Conversions API (boost match rate for retargeting) ───
# Meta: Events Manager → Settings → Conversions API → Generate access token
META_CAPI_TOKEN=                                 # Meta Conversions API access token
META_TEST_EVENT_CODE=                            # optional: TESTxxxxx (Test Events tab)
# TikTok: Events Manager → Web Events → Events API → Generate Access Token
TIKTOK_EVENTS_TOKEN=                             # TikTok Events API access token
TIKTOK_TEST_EVENT_CODE=                          # optional: test_event_code (Test Events)

# ─── SEO domain verification (set as needed) ───
NEXT_PUBLIC_GSC_VERIFICATION=                    # Google Search Console
NEXT_PUBLIC_FB_DOMAIN_VERIFICATION=              # Facebook Business / Meta domain
NEXT_PUBLIC_BING_VERIFICATION=                   # Bing Webmaster
NEXT_PUBLIC_PINTEREST_VERIFICATION=              # Pinterest domain
